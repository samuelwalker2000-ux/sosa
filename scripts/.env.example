# Daily Market Report — Email Delivery Configuration
# -------------------------------------------------------
# Copy this file to scripts/.env and fill in your values.
# NEVER commit the .env file to version control.
#
# Gmail setup (recommended):
#   1. Enable 2-Step Verification: myaccount.google.com > Security
#   2. Create an App Password: Security > App Passwords
#      - Select app: "Mail", Select device: "Windows Computer"
#      - Copy the 16-character password generated
#   3. Use that App Password as SMTP_PASSWORD below
#      (Do NOT use your regular Gmail password — it won't work)

EMAIL_FROM=samuelwalker2000@gmail.com
EMAIL_TO=samuelwalker2000@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=samuelwalker2000@gmail.com
SMTP_PASSWORD=your-16-char-app-password-here
